        "#Load DataSet\n",
        "df = pd.read_csv('/content/drive/MyDrive/XAUUSD_1 min.csv')\n",
        "print(df.head())\n",
        "print(df.columns)\n",
        "# Clean column names (IMPORTANT FIX)\n",
        "df.columns = df.columns.str.strip().str.lower()\n",
        "\n",
        "print(\"Columns after cleaning:\", df.columns)\n",
        "df['timestamp'] = pd.to_datetime(df['timestamp'])\n",
        "df = df.sort_values('timestamp').reset_index(drop = True)\n",
        "# Feature engineering\n",
        "df['candle_body'] = df['close'] - df['open']\n",
        "df['candle_range'] = df['high'] - df['low']\n",
        "df['prev_return'] = df['close'].pct_change().fillna(0)\n",
        "df['rolling_mean_5'] = df['close'].rolling(5).mean().fillna(method='bfill')\n",
        "df['rolling_std_5'] = df['close'].rolling(5).std().fillna(0)\n",
        "# Trading environment fixed for Gymnasium and case-sensitivity\n",
        "import gymnasium as gym\n",
        "from gymnasium import spaces\n",
        "\n",
        "class TradingEnv(Env):\n",
        "    def __init__(self, df):\n",
        "        super(TradingEnv, self).__init__()\n",
        "        self.df = df.reset_index(drop=True)\n",
        "        self.max_step = len(df)-1\n",
        "        self.current_step = 0\n",
        "\n",
        "        self.action_space = Discrete(3)  # 0=Hold,1=Buy,2=Sell\n",
        "        self.observation_space = Box(low=-np.inf, high=np.inf, shape=(5,), dtype=np.float32)\n",
        "\n",
        "        self.position = 0\n",
        "        self.entry_price = 0\n",
        "\n",
        "        # Trade counters\n",
        "        self.buy_profit = 0\n",
        "        self.buy_sl = 0\n",
        "        self.sell_profit = 0\n",
        "        self.sell_sl = 0\n",
        "\n",
        "    def reset(self):\n",
        "        self.current_step = 0\n",
        "        self.position = 0\n",
        "        self.entry_price = 0\n",
        "        self.buy_profit = 0\n",
        "        self.buy_sl = 0\n",
        "        self.sell_profit = 0\n",
        "        self.sell_sl = 0\n",
        "        return self._get_obs(), {}\n",
        "\n",
        "    def _get_obs(self):\n",
        "        obs = self.df.loc[self.current_step,\n",
        "                          ['candle_body','candle_range','prev_return',\n",
        "                           'rolling_mean_5','rolling_std_5']].values\n",
        "        return obs.astype(np.float32)\n",
        "\n",
        "    def step(self, action):\n",
        "        reward = 0\n",
        "        terminated = False\n",
        "        truncated = False\n",
        "\n",
        "        price = self.df.loc[self.current_step, 'close']\n",
        "\n",
        "        # If switching position → close previous trade\n",
        "        if action == 1:  # Buy\n",
        "            if self.position == -1:\n",
        "                pnl = self.entry_price - price\n",
        "                reward += pnl\n",
        "                if pnl > 0:\n",
        "                    self.sell_profit += 1\n",
        "                else:\n",
        "                    self.sell_sl += 1\n",
        "                self.position = 0\n",
        "\n",
        "            if self.position == 0:\n",
        "                self.position = 1\n",
        "                self.entry_price = price\n",
        "\n",
        "        elif action == 2:  # Sell\n",
        "            if self.position == 1:\n",
        "                pnl = price - self.entry_price\n",
        "                reward += pnl\n",
        "                if pnl > 0:\n",
        "                    self.buy_profit += 1\n",
        "                else:\n",
        "                    self.buy_sl += 1\n",
        "                self.position = 0\n",
        "\n",
        "            if self.position == 0:\n",
        "                self.position = -1\n",
        "                self.entry_price = price\n",
        "\n",
        "        self.current_step += 1\n",
        "\n",
        "        if self.current_step >= self.max_step:\n",
        "            terminated = True\n",
        "\n",
        "            # Close final position\n",
        "            final_price = self.df.loc[self.current_step-1, 'close']\n",
        "\n",
        "            if self.position == 1:\n",
        "                pnl = final_price - self.entry_price\n",
        "                if pnl > 0:\n",
        "                    self.buy_profit += 1\n",
        "                else:\n",
        "                    self.buy_sl += 1\n",
        "\n",
        "            elif self.position == -1:\n",
        "                pnl = self.entry_price - final_price\n",
        "                if pnl > 0:\n",
        "                    self.sell_profit += 1\n",
        "                else:\n",
        "                    self.sell_sl += 1\n",
        "\n",
        "        return self._get_obs(), reward, terminated, truncated, {}\n",
        "from stable_baselines3.common.vec_env import DummyVecEnv\n",
        "from stable_baselines3 import PPO\n",
        "\n",
        "# Cell 4: Initialize RL environment (FIXED)\n",
        "\n",
        "env = DummyVecEnv([lambda: TradingEnv(df)])\n",
        "\n",
        "# Initialize PPO agent\n",
        "model = PPO(\"MlpPolicy\", env, verbose=1)\n",
        "test_env = TradingEnv(df)\n",
        "\n",
        "obs, _ = test_env.reset()\n",
        "done = False\n",
        "profits_list = []\n",
        "\n",
        "while not done:\n",
        "    action, _ = model.predict(obs.reshape(1, -1))\n",
        "    action = action[0]\n",
        "\n",
        "    obs, reward, terminated, truncated, info = test_env.step(action)\n",
        "    done = terminated or truncated\n",
        "\n",
        "    profits_list.append(reward)\n",
        "\n",
        "print(\"=== RL PPO Trade Results ===\")\n",
        "print(f\"Buy Profit Count: {test_env.buy_profit}\")\n",
        "print(f\"Buy Stop-Loss Count: {test_env.buy_sl}\")\n",
        "print(f\"Sell Profit Count: {test_env.sell_profit}\")\n",
        "print(f\"Sell Stop-Loss Count: {test_env.sell_sl}\")\n",
        "print(f\"Total Profit Points: {round(sum(profits_list),2)}\")\n",
        "# Cell 7: Plot cumulative profit\n",
        "plt.figure(figsize=(12,5))\n",
        "plt.plot(np.cumsum(profits_list), label='Cumulative Profit')\n",
        "plt.xlabel('Step')\n",
        "plt.ylabel('Profit Points')\n",
        "plt.title('RL PPO Agent Cumulative Profit')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "# =========================\n",
        "# METRICS CALCULATION\n",
        "# =========================\n",
        "\n",
        "buy_wins  = test_env.buy_profit\n",
        "buy_loss  = test_env.buy_sl\n",
        "sell_wins = test_env.sell_profit\n",
        "sell_loss = test_env.sell_sl\n",
        "\n",
        "total_wins  = buy_wins + sell_wins\n",
        "total_loss  = buy_loss + sell_loss\n",
        "total_trades = total_wins + total_loss\n",
        "\n",
        "accuracy = total_wins / total_trades if total_trades > 0 else 0\n",
        "\n",
        "total_profit_points = sum([p for p in profits_list if p > 0])\n",
        "total_loss_points   = sum([p for p in profits_list if p < 0])\n",
        "\n",
        "net_profit = sum(profits_list)\n",
        "\n",
        "print(\"\\n========== PERFORMANCE ==========\")\n",
        "print(\"Total Trades:\", total_trades)\n",
        "print(\"Wins:\", total_wins)\n",
        "print(\"Losses:\", total_loss)\n",
        "print(\"Accuracy:\", round(accuracy*100,2), \"%\")\n",
        "\n",
        "print(\"\\nPoints:\")\n",
        "print(\"Total Profit Points:\", round(total_profit_points,2))\n",
        "print(\"Total Loss Points:\", round(total_loss_points,2))\n",
        "print(\"Net Profit:\", round(net_profit,2))\n",
        "\n",
        "print(\"\\nBuy Wins:\", buy_wins)\n",
        "print(\"Buy Loss:\", buy_loss)\n",
        "print(\"Sell Wins:\", sell_wins)\n",
        "print(\"Sell Loss:\", sell_loss)"
