        "class HybridTradingEnv(gym.Env):\n",
        "\n",
        "    def __init__(self, data, lstm_model, seq_len=30):\n",
        "        super().__init__()\n",
        "\n",
        "        self.data = data  # shape (N,5)\n",
        "        self.lstm = lstm_model\n",
        "        self.seq_len = seq_len\n",
        "\n",
        "        self.current_step = seq_len\n",
        "        self.max_step = len(data) - 1\n",
        "\n",
        "        self.observation_space = gym.spaces.Box(\n",
        "            low=-np.inf, high=np.inf,\n",
        "            shape=(5,),  # MUST MATCH PPO\n",
        "            dtype=np.float32\n",
        "        )\n",
        "\n",
        "        self.action_space = gym.spaces.Discrete(3)\n",
        "\n",
        "    def reset(self, seed=None, options=None):\n",
        "        self.current_step = self.seq_len\n",
        "        return self.data[self.current_step].astype(np.float32), {}\n",
        "\n",
        "    def step(self, action):\n",
        "\n",
        "        reward = 0\n",
        "        terminated = False\n",
        "\n",
        "        # LSTM confidence\n",
        "        seq = self.data[self.current_step-self.seq_len:self.current_step]\n",
        "        tp_pred, sl_pred = self.lstm.predict(\n",
        "            seq.reshape(1, self.seq_len, -1), verbose=0\n",
        "        )[0]\n",
        "\n",
        "        confidence = tp_pred - sl_pred\n",
        "\n",
        "        price_change = self.data[self.current_step][0]  # or close diff if you prefer\n",
        "\n",
        "        if action == 1:\n",
        "            reward = price_change * confidence\n",
        "        elif action == 2:\n",
        "            reward = -price_change * confidence\n",
        "\n",
        "        self.current_step += 1\n",
        "\n",
        "        if self.current_step >= self.max_step:\n",
        "            terminated = True\n",
        "\n",
        "        return self.data[self.current_step].astype(np.float32), reward, terminated, False, {}\n"
